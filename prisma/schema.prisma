generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  password     String    @default("")
  image        String?
  role         String    @default("USER")
  isBanned     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  listings      Listing[]
  offers        Offer[]
  negotiations  Negotiation[]
  buyerThreads  Thread[]  @relation("BuyerThreads")

  @@map("users")
}

model Brand {
  id        String       @id @default(cuid())
  name      String       @unique
  slug      String       @unique
  createdAt DateTime     @default(now())
  models    WatchModel[]

  @@map("brands")
}

model WatchModel {
  id         String      @id @default(cuid())
  brandId    String
  name       String
  slug       String
  reference  String?
  createdAt  DateTime    @default(now())
  listings   Listing[]
  valuations Valuation[]
  brand      Brand       @relation(fields: [brandId], references: [id])

  @@unique([brandId, slug])
  @@map("watch_models")
}

model Listing {
  id           String         @id @default(cuid())
  userId       String
  modelId      String
  title        String
  description  String?
  price        Float
  currency     String         @default("USD")
  condition    String         @default("EXCELLENT")
  hasBox       Boolean        @default(false)
  hasPapers    Boolean        @default(false)
  status       String         @default("PENDING")
  soldAt       DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  images       ListingImage[]
  model        WatchModel     @relation(fields: [modelId], references: [id])
  user         User           @relation(fields: [userId], references: [id])
  negotiations Negotiation[]
  valuation    Valuation?

  @@map("listings")
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  url       String
  publicId  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_images")
}

model Valuation {
  id             String     @id @default(cuid())
  listingId      String     @unique
  modelId        String
  chrono24Price  Float?
  mlPrice        Float?
  localDelta     Float?
  conditionDelta Float?
  boxPapersDelta Float?
  notes          String?
  sources        String     @default("[]")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  listing        Listing    @relation(fields: [listingId], references: [id])
  model          WatchModel @relation(fields: [modelId], references: [id])

  @@map("valuations")
}

model Negotiation {
  id        String            @id @default(cuid())
  listingId String
  buyerId   String
  status    String            @default("ACTIVE")
  round     Int               @default(1)
  expiresAt DateTime
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  listing   Listing           @relation(fields: [listingId], references: [id])

  buyer     User              @relation(fields: [buyerId], references: [id]) // ✅ ESTA ES LA CLAVE

  offers    Offer[]
  thread    Thread?

  @@map("negotiations")
}

model Offer {
  id            String      @id @default(cuid())
  negotiationId String
  userId        String
  amount        Float
  currency      String      @default("USD")
  reasonType    String
  reasonNote    String?
  status        String      @default("PENDING")
  createdAt     DateTime    @default(now())
  negotiation   Negotiation @relation(fields: [negotiationId], references: [id])
  user          User        @relation(fields: [userId], references: [id])

  @@map("offers")
}

model Thread {
  id            String      @id @default(cuid())
  negotiationId String      @unique
  buyerId       String
  createdAt     DateTime    @default(now())
  messages      Message[]
  buyer         User        @relation("BuyerThreads", fields: [buyerId], references: [id])
  negotiation   Negotiation @relation(fields: [negotiationId], references: [id])

  @@map("threads")
}

model Message {
  id        String   @id @default(cuid())
  threadId  String
  senderId  String?
  content   String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  thread    Thread   @relation(fields: [threadId], references: [id])

  @@map("messages")
}

model Sale {
  id         String   @id @default(cuid())
  listingId  String   @unique
  sellerId   String
  buyerId    String?
  finalPrice Float?
  currency   String   @default("USD")
  reportedAt DateTime @default(now())

  @@map("sales")
}


