generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  listings           Listing[]
  offers             Offer[]
  buyerThreads       Thread[]      @relation("BuyerThreads")
  buyerNegotiations  Negotiation[] @relation("NegotiationBuyer")
  salesAsSeller      Sale[]        @relation("SaleSeller")
  salesAsBuyer       Sale[]        @relation("SaleBuyer")
  messagesSent       Message[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Brand {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  models    WatchModel[]

  @@map("brands")
}

model WatchModel {
  id        String   @id @default(cuid())
  brandId   String
  name      String
  slug      String
  reference String?
  createdAt DateTime @default(now())

  brand     Brand      @relation(fields: [brandId], references: [id])
  listings  Listing[]
  valuations Valuation[]

  @@unique([brandId, slug])
  @@map("watch_models")
}

model Listing {
  id          String        @id @default(cuid())
  userId      String
  modelId     String
  title       String
  description String?
  price       Decimal       @db.Decimal(12, 2)
  currency    String        @default("USD")
  condition   Condition
  hasBox      Boolean       @default(false)
  hasPapers   Boolean       @default(false)
  status      ListingStatus @default(PENDING)
  soldAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  model        WatchModel    @relation(fields: [modelId], references: [id])
  images       ListingImage[]
  valuation    Valuation?
  negotiations Negotiation[]
  sale         Sale?

  @@index([status, createdAt])
  @@index([modelId])
  @@map("listings")
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_images")
}

model Valuation {
  id              String     @id @default(cuid())
  listingId       String     @unique
  modelId         String
  chrono24Price   Decimal?   @db.Decimal(12, 2)
  mlPrice         Decimal?   @db.Decimal(12, 2)
  localDelta      Decimal?   @db.Decimal(5, 2)
  conditionDelta  Decimal?   @db.Decimal(5, 2)
  boxPapersDelta  Decimal?   @db.Decimal(5, 2)
  notes           String?
  sources         Json       @default("[]")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  listing         Listing    @relation(fields: [listingId], references: [id])
  model           WatchModel @relation(fields: [modelId], references: [id])

  @@map("valuations")
}

model Negotiation {
  id        String            @id @default(cuid())
  listingId String
  buyerId   String
  status    NegotiationStatus @default(ACTIVE)
  round     Int               @default(1)
  expiresAt DateTime
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  listing   Listing           @relation(fields: [listingId], references: [id])
  buyer     User              @relation("NegotiationBuyer", fields: [buyerId], references: [id])
  offers    Offer[]
  thread    Thread?

  @@index([listingId, buyerId])
  @@map("negotiations")
}

model Offer {
  id            String      @id @default(cuid())
  negotiationId String
  userId        String
  amount        Decimal     @db.Decimal(12, 2)
  currency      String      @default("USD")
  reasonType    String
  reasonNote    String?
  status        OfferStatus @default(PENDING)
  createdAt     DateTime    @default(now())

  negotiation   Negotiation @relation(fields: [negotiationId], references: [id])
  user          User        @relation(fields: [userId], references: [id])

  @@map("offers")
}

model Thread {
  id            String    @id @default(cuid())
  negotiationId String    @unique
  buyerId       String
  createdAt     DateTime  @default(now())

  negotiation   Negotiation @relation(fields: [negotiationId], references: [id])
  buyer         User        @relation("BuyerThreads", fields: [buyerId], references: [id])
  messages      Message[]

  @@map("threads")
}

model Message {
  id        String   @id @default(cuid())
  threadId  String
  senderId  String?
  content   String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  thread    Thread   @relation(fields: [threadId], references: [id])
  sender    User?    @relation(fields: [senderId], references: [id])

  @@index([threadId, createdAt])
  @@map("messages")
}

// Sale is recorded when a listing is marked sold; keeps history even if listing row is archived later.
model Sale {
  id          String   @id @default(cuid())
  listingId   String   @unique
  sellerId    String
  buyerId     String?
  finalPrice  Decimal? @db.Decimal(12, 2)
  currency    String   @default("USD")
  reportedAt  DateTime @default(now())

  listing  Listing @relation(fields: [listingId], references: [id])
  seller   User    @relation("SaleSeller", fields: [sellerId], references: [id])
  buyer    User?   @relation("SaleBuyer", fields: [buyerId], references: [id])

  @@map("sales")
}

enum Condition {
  NEW
  MINT
  EXCELLENT
  GOOD
  FAIR
}

enum ListingStatus {
  PENDING
  APPROVED
  SOLD
  REJECTED
  EXPIRED
}

enum NegotiationStatus {
  ACTIVE
  ACCEPTED
  REJECTED
  EXPIRED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTERED
}